  "identifier": "com.zhaomc.pcnovelreader",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEQ0NFNERCNkJFQ0QxODEKUldTQjBleHIyK1RNZllpZEF0MDc3U1J6ZjdGNDN5anR5UWhPd2xGMElmby9Ma2hoa0krTWpIL0UK",
      "endpoints": [
        "https://github.com/zhaomc911/pc-novel-reader/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "PC Novel Reader",
        "width": 1200,
        "height": 820,
